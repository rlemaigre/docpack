// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "Docpack",
	"image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",
	"features": {
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/python:1": {},
		"ghcr.io/aqua/devcontainer-antigravity-cli/antigravity-cli:1": {}
	},
	"postCreateCommand": "curl -fsSL https://pi.dev/install.sh | sh",
	"customizations": {
		"vscode": {
			"extensions": [
				"cdervis.vscode-pi"
			]
		}
	},
	"mounts": [
		"source=${localEnv:HOME}/.pi,target=/home/node/.pi,type=bind"
	],
	"runArgs": [
		"--network=host"
	]
}